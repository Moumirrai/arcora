{
  "name": "arcora",
  "version": "0.0.1",
  "author": "Moumirrai",
  "main": "dist/index.js",
  "module": "src/index.ts",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.8.3",
    "tsdown": "^0.18.4",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "wasm:dev": "cd zig && zig build",
    "wasm:dist": "cd zig && zig build --prefix ../dist",
    "build:js": "tsdown",
    "build": "bun run build:js && bun run wasm:dist",
    "test": "bun run wasm:dev && vitest",
    "test-ui": "bun run wasm:dev && vitest --ui",
    "bench": "bun run wasm:dev && vitest bench",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "check": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" && eslint src/**/*.ts && bun run wasm:dev && vitest run"
  },
  "type": "module",
  "dependencies": {
    "mathjs": "^15.2.0",
    "uuid": "^13.0.2",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
