{
  "name": "arcora",
  "version": "0.0.1",
  "author": "Moumirrai",
  "main": "dist/index.js",
  "module": "lib/index.ts",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.18.4",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18",
    "@types/node": "^25.5.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "zig build && tsdown && cp zig-out/bin/arcora.wasm dist/arcora.wasm",
    "build:wasm": "zig build",
    "test": "zig build test-zig --summary all && zig build && vitest",
    "test:zig": "zig build test-zig --summary all",
    "test-ui": "zig build && vitest --ui",
    "bench": "vitest bench",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "type": "module"
}
